{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/$1"
    },
    {
      "src": "/exams/(.*)",
      "dest": "exams/$1"
    },
    {
      "src": "/(.*)",
      "dest": "web/$1"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.9"
  },
  "name": "telc-b2-mock-exam-generator",
  "buildCommand": "pip install -r requirements.txt && python3 generate_exam.py"
}
